# Пенсионный портфель — Шаблон локальных настроек
# ============================================
# Скопируйте этот файл в env.local и заполните своими данными

# ============================================
# TINKOFF INVEST API
# ============================================
TINKOFF_TOKEN=your_tinkoff_token_here

# ============================================
# CLOUDFLARE WORKER
# ============================================
WORKER_URL=https://pension-portfolio-worker.kostik.workers.dev

# ============================================
# ПОДПИСЬ APK (Keystore)
# ============================================
storeFile=../release-key.jks
storePassword=your_store_password
keyAlias=pension-portfolio
keyPassword=your_key_password

# ============================================
# CLOUDFLARE ACCOUNT
# ============================================
KV_NAMESPACE_ID=your_kv_namespace_id_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
